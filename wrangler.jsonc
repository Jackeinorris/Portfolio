{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "portfolio",
  "compatibility_date": "2026-04-25",
  "workers_dev": false,
  "observability": {
    "enabled": true
  },
  "routes": [
    { "pattern": "jvdiasfilms.com.br", "custom_domain": true },
    { "pattern": "www.jvdiasfilms.com.br", "custom_domain": true }
  ],
  "assets": {
    "directory": ".",
    "not_found_handling": "404-page"
  }
}
